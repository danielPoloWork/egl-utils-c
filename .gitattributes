# d4np-c — archive export rules.
#
# `export-ignore` strips a path from `git archive`, which is what GitHub serves as the
# "Source code (zip/tar.gz)" assets on a release/tag. The result is an implementation-only
# bundle: the library sources + headers + the CMake needed to build/consume it, with the
# development scaffolding (agent contracts, docs, tests, benchmarks, tooling, CI) removed.
#
# NOTE: this affects archives only. A `git clone` always gets the full tree.
# Kept in the bundle: d4np/, cmake/, CMakeLists.txt, CMakePresets.json,
#                     LICENSE, README.md, CHANGELOG.md, SECURITY.md.

# --- development scaffolding (not part of the shipped library) ---
.github/                export-ignore
docs/                   export-ignore
tests/                  export-ignore
bench/                  export-ignore
tools/                  export-ignore
# packaging/ (vcpkg port + Conan recipe) is distribution metadata for maintainers, not part of
# the library a bundle consumer builds. It is also kept out so the vcpkg portfile's SHA512 — which
# pins this very archive — is not part of the archive it checksums (that would be circular).
packaging/              export-ignore

# --- agent / AI contracts ---
AGENTS.md               export-ignore
CLAUDE.md               export-ignore
GEMINI.md               export-ignore

# --- planning / spec / dev meta files ---
ROADMAP.md              export-ignore
.clang-format           export-ignore
.clang-tidy             export-ignore
.gitignore              export-ignore
.gitattributes          export-ignore
